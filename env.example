# Copy this file to .env and fill in your real values.
# Do not commit .env to Git.

LARGE_MODEL_ENABLED=true
LARGE_MODEL_PROVIDER=doubao
LARGE_MODEL_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
ARK_API_KEY=your_volcengine_ark_api_key_here
ARK_MODEL=doubao-seed-1-8-251228
ARK_REASONING_EFFORT=medium
ARK_MAX_COMPLETION_TOKENS=4096
LARGE_MODEL_TIMEOUT_SECONDS=60
